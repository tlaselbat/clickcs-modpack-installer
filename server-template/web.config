<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS configuration for ClickCS Valheim modpack hosting.
  Place this in the root of your IIS site/virtual directory.
-->
<configuration>
  <system.webServer>
    <!-- MIME types for mod files -->
    <staticContent>
      <remove fileExtension=".json" />
      <remove fileExtension=".dll" />
      <remove fileExtension=".cfg" />
      <remove fileExtension=".ini" />
      <remove fileExtension=".txt" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <mimeMap fileExtension=".dll" mimeType="application/octet-stream" />
      <mimeMap fileExtension=".cfg" mimeType="text/plain" />
      <mimeMap fileExtension=".ini" mimeType="text/plain" />
      <mimeMap fileExtension=".txt" mimeType="text/plain" />
    </staticContent>

    <!-- Disable directory browsing -->
    <directoryBrowse enabled="false" />

    <!-- Cache headers -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
      </customHeaders>
    </httpProtocol>

    <!-- URL rewrite: no-cache for manifest.json -->
    <rewrite>
      <outboundRules>
        <rule name="NoCacheManifest" preCondition="IsManifest">
          <match serverVariable="RESPONSE_Cache-Control" pattern=".*" />
          <action type="Rewrite" value="no-cache, no-store, must-revalidate" />
        </rule>
        <preConditions>
          <preCondition name="IsManifest">
            <add input="{REQUEST_FILENAME}" pattern="manifest\.json$" />
          </preCondition>
        </preConditions>
      </outboundRules>
    </rewrite>

    <!-- Allow large file downloads (2GB) -->
    <requestFiltering>
      <requestLimits maxAllowedContentLength="2147483648" />
    </requestFiltering>
  </system.webServer>
</configuration>
