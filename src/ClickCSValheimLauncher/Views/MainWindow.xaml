<Window x:Class="ClickCSValheimLauncher.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ClickCSValheimLauncher.ViewModels"
        Style="{StaticResource DarkWindowStyle}"
        Title="{Binding LauncherVersion, StringFormat='ClickCS Valheim Modpack Installer v{0}'}"
        Height="480" Width="520"
        MinHeight="420" MinWidth="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <Button Content="⚙" DockPanel.Dock="Right" ToolTip="Settings" Margin="4,0,0,0"
                    Click="SettingsButton_Click" Width="32" Height="32"/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="⚔ ClickCS Valheim Modpack Installer" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"/>
                <TextBlock Text="{Binding LauncherVersion, StringFormat=' v{0}'}" 
                           FontSize="11" VerticalAlignment="Bottom" Margin="4,0,0,3"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </DockPanel>

        <!-- Launcher Update Banner -->
        <Border Grid.Row="1" Background="#33FFC107" CornerRadius="4" Padding="8" Margin="0,0,0,8"
                Visibility="{Binding AvailableLauncherUpdate, Converter={StaticResource NullToVisibilityConverter}, FallbackValue=Collapsed}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Update" Style="{StaticResource AccentButton}"
                        Command="{Binding UpdateLauncherCommand}" Margin="8,0,0,0"/>
                <TextBlock VerticalAlignment="Center">
                    <Run Text="🔄 Launcher update: v"/>
                    <Run Text="{Binding AvailableLauncherUpdate.Version, Mode=OneWay}"/>
                </TextBlock>
            </DockPanel>
        </Border>

        <!-- Profile + Status (compact) -->
        <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" 
                CornerRadius="4" Padding="12" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Server name (static) -->
                <TextBlock Grid.Row="0" Margin="0,0,0,8" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}" Text="⚔ Tablet &amp; Lex's Valheim World"/>

                <!-- Version info (single line) -->
                <StackPanel Grid.Row="1" Orientation="Horizontal">
                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}">
                        <Run Text="Installed: "/><Run Text="{Binding InstalledVersion, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <Run Text="   Latest: "/><Run Text="{Binding LatestVersion, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Actions (big buttons) -->
        <UniformGrid Grid.Row="3" Columns="3" Margin="0,0,0,10">
            <Button Content="⬇ Update" Style="{StaticResource AccentButton}" Margin="0,0,4,0"
                    ToolTip="Check and install updates (backs up first)"
                    Command="{Binding UpdateCommand}"/>
            <Button Content="🔧 Repair" Margin="2,0"
                    ToolTip="Re-verify and fix all files"
                    Command="{Binding RepairCommand}"/>
            <Button Content="🚀 Launch" Style="{StaticResource AccentButton}" Margin="4,0,0,0"
                    ToolTip="Launch Valheim and connect to server"
                    Command="{Binding LaunchValheimCommand}"/>
        </UniformGrid>

        <!-- Progress + Status -->
        <StackPanel Grid.Row="4" Margin="0,0,0,8">
            <TextBlock Text="{Binding StatusText}" Margin="0,0,0,4" FontSize="12"
                       TextTrimming="CharacterEllipsis" ToolTip="{Binding StatusText}"/>
            <ProgressBar Value="{Binding Progress}" Maximum="100" Height="6"
                         IsIndeterminate="{Binding IsIndeterminate}"/>
        </StackPanel>

        <!-- Collapsible details (log + extra actions) -->
        <Expander Grid.Row="5" Header="Details" Foreground="{StaticResource TextSecondaryBrush}"
                  IsExpanded="False">
            <DockPanel Margin="0,6,0,0">
                <!-- Bottom toolbar -->
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,6,0,0">
                    <Button Content="↩ Rollback" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,4,0"
                            ToolTip="Restore from a previous backup" Click="RollbackButton_Click"/>
                    <Button Content="� Folder" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,4,0"
                            ToolTip="Open Valheim folder" Command="{Binding OpenValheimFolderCommand}"/>
                    <Button Content="📋 Logs" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,4,0"
                            Command="{Binding OpenLogsCommand}"/>
                    <Button Content="Copy Log" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,4,0"
                            Command="{Binding CopyLogCommand}"/>
                    <Button Content="✕ Cancel" Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding CancelOperationCommand}"
                            Visibility="{Binding IsWorking, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>

                <!-- Log box -->
                <TextBox Text="{Binding LogOutput, Mode=OneWay}" 
                         IsReadOnly="True" 
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap"
                         FontFamily="Consolas" FontSize="10"
                         Background="{StaticResource SurfaceBrush}"
                         x:Name="LogTextBox"/>
            </DockPanel>
        </Expander>
    </Grid>
</Window>
