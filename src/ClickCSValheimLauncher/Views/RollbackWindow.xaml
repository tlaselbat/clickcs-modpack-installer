<Window x:Class="ClickCSValheimLauncher.Views.RollbackWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource DarkWindowStyle}"
        Title="Rollback - ClickCS Valheim Launcher"
        Height="400" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Available Backups" FontSize="16" FontWeight="SemiBold"
                   Foreground="{StaticResource AccentBrush}" Margin="0,0,0,12"/>

        <ListBox Grid.Row="1" x:Name="BackupList" Margin="0,0,0,12"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Restore Selected" Style="{StaticResource AccentButton}" 
                    Margin="0,0,8,0" Click="Restore_Click"/>
            <Button Content="Close" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
