<Window x:Class="ClickCSValheimLauncher.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource DarkWindowStyle}"
        Title="Settings - ClickCS Valheim Launcher"
        Height="450" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <StackPanel Margin="16">
        <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold" 
                   Foreground="{StaticResource AccentBrush}" Margin="0,0,0,16"/>

        <GroupBox Header="Paths">
            <StackPanel>
                <Label Content="Valheim Install Path"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ValheimPathBox" Grid.Column="0"/>
                    <Button Grid.Column="1" Content="Browse" Margin="4,0,0,0" Click="BrowseValheim_Click"/>
                    <Button Grid.Column="2" Content="Detect" Margin="4,0,0,0" Click="DetectValheim_Click"/>
                </Grid>

                <Label Content="Steam Install Path"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SteamPathBox" Grid.Column="0"/>
                    <Button Grid.Column="1" Content="Browse" Margin="4,0,0,0" Click="BrowseSteam_Click"/>
                </Grid>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="Updates">
            <StackPanel>
                <Label Content="Launcher Update URL"/>
                <TextBox x:Name="UpdateUrlBox" Margin="0,0,0,8"/>
                <CheckBox x:Name="CheckUpdatesBox" Content="Check for updates on startup" Margin="0,4"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="Security">
            <StackPanel>
                <CheckBox x:Name="AllowHttpBox" Content="Allow insecure HTTP connections (not recommended)" Margin="0,4"/>
                <Label Content="Clear clipboard after (seconds):"/>
                <TextBox x:Name="ClipboardSecondsBox" Width="80" HorizontalAlignment="Left" Margin="0,0,0,4"/>
            </StackPanel>
        </GroupBox>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Save" Style="{StaticResource AccentButton}" Margin="0,0,8,0" Click="Save_Click"/>
            <Button Content="Cancel" Click="Cancel_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
